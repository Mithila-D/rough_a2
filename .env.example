# ── Choose your LLM backend ──────────────────────────────────────────────────
# "ollama"  → local Llama 3 via Ollama (free, no quota, recommended)
# "gemini"  → Google Gemini API (requires key below)
LLM_BACKEND=ollama

# ── Ollama settings (only needed if LLM_BACKEND=ollama) ─────────────────────
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ── Gemini settings (only needed if LLM_BACKEND=gemini) ─────────────────────
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.0-flash-lite
